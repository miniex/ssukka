root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.rs]
indent_style = space
indent_size = 4

# shfmt reads .editorconfig - shell scripts use tab indentation.
[*.sh]
indent_style = tab
binary_next_line = true
switch_case_indent = true

[*.{toml,yml,yaml,json}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
